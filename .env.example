# Stripe — required for Pro checkout
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# Create products/prices at https://dashboard.stripe.com/products
# Monthly: $4.99 recurring, Yearly: $39.99 recurring
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...

# Stripe Webhook — required for Pro API key generation
# Create webhook at https://dashboard.stripe.com/webhooks
# Point to https://devbolt.dev/api/webhook
# Events: checkout.session.completed, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...
